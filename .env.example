DEFAULT_ADMIN_USERNAME=your_admin_username
DEFAULT_ADMIN_PASSWORD=your_admin_password

# Airtable Configuration
# Get your API key from: https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_airtable_api_key_here
# Base ID can be found in the URL: https://airtable.com/app___YOUR_BASE_ID___/...
AIRTABLE_BASE_ID=your_airtable_base_id_here
# Table name (should match exactly the name in Airtable)
AIRTABLE_TABLE_NAME=Resources
